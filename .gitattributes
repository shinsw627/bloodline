# Normalize line endings for text files
* text=auto eol=lf

# Godot text formats
*.gd        text eol=lf
*.tscn      text eol=lf
*.tres      text eol=lf
*.godot     text eol=lf
*.cfg       text eol=lf
*.import    text eol=lf

# Treat as binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.webp      binary
*.ogg       binary
*.wav       binary
*.mp3       binary
*.ttf       binary
*.otf       binary

# LFS candidates (enable with `git lfs track` when needed in M3+)
# *.png      filter=lfs diff=lfs merge=lfs -text
# *.ogg      filter=lfs diff=lfs merge=lfs -text
